//- file: src/components/metar/wind/wind.pug

// Wind

div
  div
    label
      span.wre_bold Ветер
  div
    label
      input(type='radio' name='units' value='MPS' id='amtk_metar_units_mps')
      span.wre_normal MPS
    label
      input(type='radio' name='units' value='KT' id='amtk_metar_units_kt')
      span.wre_normal KT
    label
      input(type='checkbox' name='calm' value='CALM' id='amtk_metar_calm')
      span.wre_normal CALM
    label
      input(type='checkbox' name='vrb' value='VRB' id='amtk_metar_vrb')
      span.wre_normal VRB
  div
    div
      div
        label(for='amtk_metar_direction')
          span.wre_normal Направление
        //label(for='amtk_metar_vrb')
        //  input(type='checkbox' name='vrb' value='VRB' id='amtk_metar_vrb')
        //  span VRB
      div.amtk_flex_row.amtk_flex_gap_sm
        input.amtk_wre_input_text(type='text' name='direction' id='amtk_metar_direction')
        input(type='range' name='direction_range' min='-10' max='360' step='10' value='-10' id='amtk_metar_direction_range')
    div
      div
        label(for='amtk_metar_speed')
          span.wre_normal Скорость
      div.amtk_flex_row.amtk_flex_gap_sm
        input.amtk_wre_input_text(type='text' name='speed' id='amtk_metar_speed')
        input(type='range' name='speed_range' min='-1' max='99' step='1' value='-1' id='amtk_metar_speed_range')
    div
      div
        label(for='amtk_metar_gust')
          span.wre_normal Порыв
      div.amtk_flex_row.amtk_flex_gap_sm
        input.amtk_wre_input_text(type='text' name='gust' id='amtk_metar_gust')
        input(type='range' name='gust_range' min='-1' max='99' step='1' value='-1' id='amtk_metar_gust_range')
