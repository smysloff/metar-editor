// src/components/metar/main/main.styl

.mrbox-scroll:has(.amtk_metar_editor)
  padding-bottom 0

.amtk_wre
  box-sizing border-box
  position relative
  width 728px
  margin-left auto
  margin-right @margin-left

  form
    padding-left 1rem
    padding-right @padding-left

  form[name='amtk_form_output']
    position sticky
    bottom 0
    background-color #f6f6f6
    border-top 1px solid currentColor
    padding-top 1rem
    padding-bottom @padding-top

  div
    margin-bottom .5rem

  hr
    margin-top 1.5rem
    margin-bottom @margin-top

  input[type='text']
  input[type='date']
  input[type='time']
  input[type='button']
  textarea
  select
    box-sizing border-box

  input[type='range']
  textarea
    width 100%

  textarea
    margin-bottom 1rem

  summary
    text-decoration underline
    cursor pointer

  label
    white-space nowrap
    margin-bottom 0

    & > input[type='radio']
    & > input[type='checkbox']
      margin-block-end 0px
      margin-block-start 3px
      margin-inline-end 3px
      margin-inline-start 5px
      margin-bottom 0px
      margin-left 5px
      margin-right 3px
      margin-top 3px

  .wre_normal
    font-weight normal

  .wre_bold
    font-weight bold

  .flex
  .wre_flex
    display flex

  .amtk_hidden
  .wre_hidden
    display none !important

  .amtk_wre_w10
    width 10rem

  input
  textarea
  select
  option
    font inherit

  #amtk_metar_icao
  #amtk_metar_direction
  #amtk_metar_speed
  #amtk_metar_gust
    width calc(11ch + 2.25rem)

  div
    & > input + input
    & > input + select
    & > input + label
    & > select + select
    & > select + input
    & > select + label
    & > label + label
    & > label + select
    & > label + input
      margin-left .5rem

  summary
    & + div
      margin-top .5rem

  #amtk_metar_icao
    width 4ch !important
    box-sizing initial
    padding .25rem
    margin 0
    font-family monospace

  select[name="icao_variants"]
    box-sizing initial
    padding .25rem
    margin-top 0
    margin-right 0
    margin-bottom 0
    font-family monospace

  #amtk_metar_date
    box-sizing initial
    padding .25rem
    margin 0
    font-family monospace

  #amtk_metar_time
    box-sizing initial
    padding .25rem
    margin-top 0
    margin-right 0
    margin-bottom 0
    font-family monospace

  #amtk_metar_current
    box-sizing initial
    padding .25rem
    margin-top 0
    margin-right 0
    margin-bottom 0
    font-family monospace

  #amtk_metar_direction
    width 4ch !important
    box-sizing initial
    padding .25rem
    margin 0
    font-family monospace

  #amtk_metar_speed
  #amtk_metar_gust
  #amtk_metar_visibility
  #amtk_metar_visibility_minimal
  #amtk_metar_visibility_vertical
  #amtk_metar_clouds_1
  #amtk_metar_clouds_2
  #amtk_metar_clouds_3
  #amtk_metar_clouds_4
  #amtk_metar_pressure
  #amtk_metar_temperature
  #amtk_metar_dew_point
    width 4ch !important
    box-sizing initial
    padding .25rem
    margin-top 0
    margin-right 0
    margin-bottom 0
    font-family monospace

  #amtk_metar_temperature_range
  #amtk_metar_dew_point_range
    width 100%

  .amtk_flex_row
    display flex
    align-items center
    flex-direction row

  .amtk_flex_gap_sm
    gap .25rem

  .amtk_flex_gap_md
    gap 1.5rem

  .amtk_flex_center
    display flex
    align-items center
    justify-content center

.wre_metar_send
.wre_metar_submit
.wre_metar_reset
.wre_metar_back
  padding .5rem .75rem
  border-radius 5px
  cursor pointer
  color #fff
  background-repeat repeat-x
  box-shadow inset 0 1px 0 rgba(255, 255, 255, .15), 0 1px 1px rgba(0, 0, 0, .075)
  border-width 1px
  margin-left 8px

  &:hover
  &:focus
    background-position 0 -15px

.wre_metar_send
  border-color #b92c28
  background-color #d9534f
  background-image linear-gradient(to bottom, #d9534f 0%, #c12e2a 100%)
  border-radius 4px

  &:hover
  &:focus
    background-color #c12e2a

.wre_metar_submit
  border-color #204d74
  background-color #286090
  background-image linear-gradient(to bottom, #337ab7 0%, #265a88 100%)

  &:hover
  &:focus
    background-color #265a88

.wre_metar_reset
.wre_metar_back
  color #333
  background-color #fff
  background-image linear-gradient(to bottom, #fff 0%, #e0e0e0 100%)

  &:hover
  &:focus
    border-color #adadad
    background-color #e0e0e0

.amtk_wre_form_output
.wre_form_output
  border-radius 3px
  border-color currentColor

.wre_form_output
  color currentColor
  border-color currentColor
  resize none
  border-width 1px
  padding .25rem

.amtk_wre_w100
  width 100%

.amtk_wre_hidden
  display none

@import '../menu/menu.styl'
